{
  "robot_id": "CINA_10003",
  "robot_name": "003 - 数据监控",
  "version": "1.0.0",
  
  "user": {
    "name": "十三先生",
    "timezone": "Asia/Shanghai",
    "language": "zh-CN"
  },
  
  "memory": {
    "structure": "three-layer",
    "longterm_path": "memory/longterm/",
    "shortterm_path": "memory/shortterm/",
    "working_path": "memory/working/"
  },
  
  "heartbeat": {
    "enabled": true,
    "frequency": "every_30min",
    "channel": "qqbot"
  },
  
  "qqbot": {
    "enabled": true,
    "chat_type": "direct"
  },
  
  "github": {
    "backup_enabled": true,
    "repo": "cinagroup/openclaw-robots-backup",
    "branch": "main",
    "auto_backup": true
  },
  
  "features": {
    "system_monitoring": true,
    "alert_notification": true,
    "data_collection": true,
    "report_generation": true
  },
  
  "notes": {
    "config_template": "此文件为配置模板，不含敏感信息",
    "sensitive_data": "敏感信息请配置在 config-local.json 或环境变量中",
    "api_key": "${API_KEY}",
    "robot_token": "${ROBOT_TOKEN}"
  }
}
