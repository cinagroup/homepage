---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';

const metadata = {
  title: 'CinaToken — Large Model API Gateway & Token Management',
  description: 'Unified API gateway for Claude, GPT, Gemini, and 100+ AI models. Simplified token management, cost optimization, and enterprise-grade reliability.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="AI API Gateway"
    title={'Unified Access to <span class="text-blue-600 dark:text-blue-400">100+ AI Models</span>'}
    subtitle="CinaToken is your gateway to the world's leading AI models. One API key, unified billing, intelligent routing, and enterprise-grade reliability for Claude, GPT, Gemini, and more."
    actions={[
      {
        variant: 'primary',
        text: 'Get API Key',
        href: '#pricing',
        icon: 'tabler:key',
      },
      { 
        text: 'View Models', 
        href: '#models',
        icon: 'tabler:cpu',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaToken API Gateway' 
    }}
  />

  <!-- Features Section -->
  <Features
    id="features"
    tagline="Core Features"
    title="Why Choose CinaToken"
    subtitle="Everything you need to integrate AI models into your applications"
    items={[
      {
        title: 'Unified API Interface',
        description: 'One API standard for Claude, GPT, Gemini, Mistral, and 100+ models. Switch models without code changes.',
        icon: 'tabler:api',
      },
      {
        title: 'Intelligent Model Routing',
        description: 'Auto-failover and load balancing across multiple providers. 99.9% uptime guaranteed.',
        icon: 'tabler:route',
      },
      {
        title: 'Cost Optimization',
        description: 'Smart routing to cheapest available model. Up to 40% cost reduction with no quality loss.',
        icon: 'tabler:wallet',
      },
      {
        title: 'Unified Billing',
        description: 'Single invoice for all AI model usage. Track spending by project, team, or endpoint.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Rate Limit Management',
        description: 'Automatic retry and backoff handling. Never hit rate limits again with intelligent queuing.',
        icon: 'tabler:clock-hour-12',
      },
      {
        title: 'Enterprise Security',
        description: 'SOC 2 compliant, data encryption at rest and in transit. Your API keys never leave our vault.',
        icon: 'tabler:shield-lock',
      },
    ]}
  />

  <!-- Supported Models -->
  <section id="models" class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Supported AI Models
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Access the world's leading AI models through a single API
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Anthropic -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700 p-6">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-orange-400 to-orange-600"></div>
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center mr-4">
              <span class="text-2xl">🤖</span>
            </div>
            <div>
              <h3 class="text-lg font-bold dark:text-white">Anthropic</h3>
              <p class="text-sm text-gray-500">Claude Series</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Claude 3.5 Sonnet</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Claude 3.5 Haiku</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Claude 3 Opus</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Claude 3.7 Sonnet</li>
          </ul>
        </div>

        <!-- OpenAI -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700 p-6">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-green-400 to-green-600"></div>
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center mr-4">
              <span class="text-2xl">🟢</span>
            </div>
            <div>
              <h3 class="text-lg font-bold dark:text-white">OpenAI</h3>
              <p class="text-sm text-gray-500">GPT Series</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>GPT-4.5 Turbo</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>GPT-4o</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>GPT-4o Mini</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>o1 / o3</li>
          </ul>
        </div>

        <!-- Google -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700 p-6">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 to-blue-600"></div>
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mr-4">
              <span class="text-2xl">🔵</span>
            </div>
            <div>
              <h3 class="text-lg font-bold dark:text-white">Google</h3>
              <p class="text-sm text-gray-500">Gemini Series</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Gemini 2.5 Pro</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Gemini 2.5 Flash</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Gemini 2.0</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Imagen 3</li>
          </ul>
        </div>

        <!-- More Providers -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700 p-6">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-purple-400 to-purple-600"></div>
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-xl flex items-center justify-center mr-4">
              <span class="text-2xl">⚡</span>
            </div>
            <div>
              <h3 class="text-lg font-bold dark:text-white">+100 More</h3>
              <p class="text-sm text-gray-500">Various Providers</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Mistral AI</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Cohere</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Groq</li>
            <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>And more...</li>
          </ul>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="#pricing" class="inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          View All 100+ Models
        </a>
      </div>
    </div>
  </section>

  <!-- API Example -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Simple API Integration
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Drop-in replacement for existing AI SDKs
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-gray-900 rounded-2xl overflow-hidden shadow-2xl">
          <div class="flex items-center px-4 py-3 bg-gray-800 border-b border-gray-700">
            <div class="flex space-x-2">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
            </div>
            <span class="ml-4 text-sm text-gray-400">API Example</span>
          </div>
          <div class="p-6 overflow-x-auto">
            <pre class="text-sm text-gray-300"><code><span class="text-purple-400">import</span> OpenAI <span class="text-purple-400">from</span> <span class="text-green-400">'openai'</span>;

<span class="text-gray-500">// Use CinaToken as your OpenAI-compatible endpoint</span>
<span class="text-purple-400">const</span> client = <span class="text-purple-400">new</span> <span class="text-yellow-400">OpenAI</span>({
  apiKey: <span class="text-green-400">'your-cinatoken-key'</span>,
  baseURL: <span class="text-green-400">'https://api.cinatoken.com/v1'</span>,
});

<span class="text-purple-400">const</span> completion = <span class="text-purple-400">await</span> client.chat.completions.<span class="text-yellow-400">create</span>({
  model: <span class="text-green-400">'claude-3-5-sonnet'</span>,  <span class="text-gray-500">// or any supported model</span>
  messages: [
    { role: <span class="text-green-400">'user'</span>, content: <span class="text-green-400">'Hello!'</span> }
  ],
});

console.<span class="text-yellow-400">log</span>(completion.choices[<span class="text-orange-400">0</span>].message.content);</code></pre>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
          <div class="text-center p-4">
            <div class="text-3xl mb-2">🔑</div>
            <h3 class="font-bold dark:text-white mb-1">One API Key</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">Access all models with single credential</p>
          </div>
          <div class="text-center p-4">
            <div class="text-3xl mb-2">🔄</div>
            <h3 class="font-bold dark:text-white mb-1">Zero Code Changes</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">Compatible with OpenAI SDK</p>
          </div>
          <div class="text-center p-4">
            <div class="text-3xl mb-2">⚡</div>
            <h3 class="font-bold dark:text-white mb-1">Instant Setup</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">Get started in under 5 minutes</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <Content
    isReversed
    tagline="Use Cases"
    title="Built for Every Scale"
    items={[
      {
        title: 'Startups & Indie Hackers',
        description: 'Pay only for what you use. No monthly commitments. Access enterprise models at startup prices.',
        icon: 'tabler:rocket',
      },
      {
        title: 'SaaS Companies',
        description: 'Reliable API infrastructure for customer-facing AI features. SLA guarantees and dedicated support.',
        icon: 'tabler:building',
      },
      {
        title: 'Enterprise Teams',
        description: 'Centralized AI spending management. Track usage by department, project, or cost center.',
        icon: 'tabler:building-skyscraper',
      },
      {
        title: 'AI Agencies',
        description: 'White-label API for your clients. Custom branding and dedicated account management.',
        icon: 'tabler:briefcase',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=1740&q=80',
      alt: 'CinaToken Use Cases',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Trusted by Developers Worldwide
      </h3>
      From solo developers to Fortune 500 companies, CinaToken powers AI applications at every scale.
    </Fragment>
  </Content>

  <!-- Pricing Section -->
  <Pricing
    id="pricing"
    tagline="Pricing Plans"
    title="Simple, Transparent Pricing"
    subtitle="No hidden fees. Pay only for what you use."
    items={[
      {
        title: 'Free',
        price: '$0',
        period: '/month',
        description: 'Perfect for testing and small projects',
        features: [
          '$5 free credit',
          'Access to all models',
          'Standard rate limits',
          'Community support',
          'Basic analytics',
        ],
        action: {
          text: 'Get Started',
          href: '#',
          variant: 'secondary',
        },
      },
      {
        title: 'Pro',
        price: '¥99',
        period: '/month',
        description: 'For production applications',
        features: [
          '$50 monthly credit',
          'Priority rate limits',
          '99.9% SLA guarantee',
          'Email support',
          'Advanced analytics',
          'Custom model routing',
          'Team collaboration',
        ],
        action: {
          text: 'Start Pro Trial',
          href: '#',
          variant: 'primary',
        },
        popular: true,
      },
      {
        title: 'Enterprise',
        price: 'Custom',
        period: '',
        description: 'For high-volume deployments',
        features: [
          'Volume discounts',
          'Dedicated infrastructure',
          'Custom SLA',
          '24/7 phone support',
          'Custom integrations',
          'White-label option',
          'On-premise deployment',
          'Dedicated account manager',
        ],
        action: {
          text: 'Contact Sales',
          href: '/contact',
          variant: 'secondary',
        },
      },
    ]}
  />

  <!-- Testimonials -->
  <Testimonials
    title="Loved by Developers"
    testimonials={[
      {
        testimonial: `CinaToken reduced our AI API costs by 35% while improving reliability. The unified API made switching between models trivial. Best decision we made this year.`,
        name: 'Alex Chen',
        job: 'CTO, AI Startup',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=500&q=80',
          alt: 'Alex Chen',
        },
      },
      {
        testimonial: `We serve 100K+ users with AI features. CinaToken's intelligent routing ensures we never hit rate limits. The analytics dashboard helps us optimize costs daily.`,
        name: 'Sarah Liu',
        job: 'Engineering Lead, SaaS Company',
        image: {
          src: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=500&q=80',
          alt: 'Sarah Liu',
        },
      },
      {
        testimonial: `As an agency, we manage AI integrations for 20+ clients. CinaToken's unified billing and white-label option made our operations so much simpler.`,
        name: 'Michael Wang',
        job: 'Founder, Digital Agency',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=500&q=80',
          alt: 'Michael Wang',
        },
      },
    ]}
  />

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Your API Key',
        href: '#',
        icon: 'tabler:key',
      },
      {
        variant: 'secondary',
        text: 'Read Documentation',
        href: '#',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to <span class="text-blue-600 dark:text-blue-400">Simplify</span> Your AI Integration?
    </Fragment>

    <Fragment slot="subtitle">
      Join thousands of developers using CinaToken. <br class="hidden md:inline" />
      Start with $5 free credit, no credit card required.
    </Fragment>
  </CallToAction>
</Layout>
