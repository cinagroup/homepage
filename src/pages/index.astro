---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BusinessCard from '~/components/business/BusinessCard.astro';

const metadata = {
  title: 'CinaGroup — AI & Web3 Solutions',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->
  <Hero
    tagline="Welcome to CinaGroup"
    title={'Building the Future of <span class="text-accent dark:text-white">AI & Web3</span>'}
    subtitle="We provide cutting-edge solutions in AI search, intelligent robots, skill platforms, and blockchain infrastructure. Empowering businesses and developers worldwide."
    actions={[
      {
        variant: 'primary',
        text: 'Explore Products',
        href: '#business',
        icon: 'tabler:arrow-down',
      },
      { 
        text: 'Contact Us', 
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'AI Technology Hero Image' 
    }}
  />

  <!-- Business Overview ************** -->
  <section id="business" class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Our Business Lines
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Four powerful platforms working together to deliver comprehensive AI and Web3 solutions
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- CinaSeek Card -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-green-400 to-green-600"></div>
          <div class="p-6">
            <div class="w-14 h-14 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold dark:text-white mb-2">CinaSeek</h3>
            <p class="text-sm text-green-600 dark:text-green-400 font-medium mb-3">Intelligent Search</p>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              AI-driven enterprise search solution with multi-source data aggregation
            </p>
            <a href="/cinaseek" class="inline-flex items-center text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300 font-medium text-sm group-hover:translate-x-1 transition-transform">
              Learn More
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- CinaClaw Card -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-orange-400 to-orange-600"></div>
          <div class="p-6">
            <div class="w-14 h-14 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold dark:text-white mb-2">CinaClaw</h3>
            <p class="text-sm text-orange-600 dark:text-orange-400 font-medium mb-3">AI Assistant</p>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              24/7 AI assistant with multi-platform integration and workflow automation
            </p>
            <a href="/cinaclaw" class="inline-flex items-center text-orange-600 dark:text-orange-400 hover:text-orange-700 dark:hover:text-orange-300 font-medium text-sm group-hover:translate-x-1 transition-transform">
              Try Demo
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- CinaSkill Card -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pink-400 to-pink-600"></div>
          <div class="p-6">
            <div class="w-14 h-14 bg-pink-100 dark:bg-pink-900/30 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold dark:text-white mb-2">CinaSkill</h3>
            <p class="text-sm text-pink-600 dark:text-pink-400 font-medium mb-3">Skills Platform</p>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              Create, share, and discover robot skills with unlimited possibilities
            </p>
            <a href="/cinaskill" class="inline-flex items-center text-pink-600 dark:text-pink-400 hover:text-pink-700 dark:hover:text-pink-300 font-medium text-sm group-hover:translate-x-1 transition-transform">
              Browse Skills
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- CinaChain Card -->
        <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-purple-400 to-purple-600"></div>
          <div class="p-6">
            <div class="w-14 h-14 bg-purple-100 dark:bg-purple-900/30 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold dark:text-white mb-2">CinaChain</h3>
            <p class="text-sm text-purple-600 dark:text-purple-400 font-medium mb-3">Blockchain Network</p>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
              High-performance, low-cost Web3 infrastructure with smart contracts and DeFi
            </p>
            <a href="/cinachain" class="inline-flex items-center text-purple-600 dark:text-purple-400 hover:text-purple-700 dark:hover:text-purple-300 font-medium text-sm group-hover:translate-x-1 transition-transform">
              View Network
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Features ****************** -->
  <Features
    tagline="Why Choose Us"
    title="Technology That Drives Innovation"
    subtitle="Built on cutting-edge technology with a focus on performance, security, and scalability"
    items={[
      {
        title: 'AI-Powered Intelligence',
        description: 'Advanced machine learning models power our search, robotics, and automation solutions.',
        icon: 'tabler:brain',
      },
      {
        title: 'Blockchain Security',
        description: 'Enterprise-grade security with decentralized architecture and cryptographic protection.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Developer First',
        description: 'Comprehensive APIs, SDKs, and documentation to accelerate your development.',
        icon: 'tabler:code',
      },
      {
        title: 'Scalable Infrastructure',
        description: 'Cloud-native architecture that scales seamlessly with your growing needs.',
        icon: 'tabler:server-2',
      },
      {
        title: 'Real-time Processing',
        description: 'Low-latency data processing and real-time analytics for time-critical applications.',
        icon: 'tabler:clock-bolt',
      },
      {
        title: '24/7 Support',
        description: 'Round-the-clock technical support and comprehensive knowledge base.',
        icon: 'tabler:headset',
      },
    ]}
  />

  <!-- Stats Section ****************** -->
  <Stats
    stats={[
      { title: 'Active Users', amount: '50K+' },
      { title: 'API Calls/Day', amount: '10M+' },
      { title: 'Skills Available', amount: '1,000+' },
      { title: 'Network Nodes', amount: '500+' },
    ]}
  />

  <!-- How It Works ******************* -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          How It Works
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Get started in three simple steps
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-blue-600 dark:text-blue-400">1</span>
          </div>
          <h3 class="text-xl font-bold dark:text-white mb-2">Choose Your Product</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Select from our four business lines based on your needs
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-blue-600 dark:text-blue-400">2</span>
          </div>
          <h3 class="text-xl font-bold dark:text-white mb-2">Integrate & Deploy</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Use our APIs and SDKs to integrate with your existing systems
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-blue-600 dark:text-blue-400">3</span>
          </div>
          <h3 class="text-xl font-bold dark:text-white mb-2">Scale & Optimize</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Monitor performance and scale as your usage grows
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials ******************* -->
  <Testimonials
    title="Trusted by Innovators"
    testimonials={[
      {
        testimonial: `CinaSeek has transformed how our team accesses information. The AI-powered search is incredibly accurate and saves us hours every day.`,
        name: 'Alex Chen',
        job: 'CTO, TechCorp',
        image: {
          src: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80',
          alt: 'Alex Chen',
        },
      },
      {
        testimonial: `CinaClaw automated 80% of our customer service inquiries. The ROI was evident within the first month of deployment.`,
        name: 'Sarah Johnson',
        job: 'Operations Director, StartupXYZ',
        image: {
          src: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80',
          alt: 'Sarah Johnson',
        },
      },
      {
        testimonial: `The CinaChain infrastructure is rock-solid. We've built our entire DeFi platform on it with zero downtime.`,
        name: 'Michael Zhang',
        job: 'Founder, Web3 Labs',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80',
          alt: 'Michael Zhang',
        },
      },
    ]}
  />

  <!-- Call to Action *************** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Started Free',
        href: '/contact',
        icon: 'tabler:rocket',
      },
      {
        variant: 'secondary',
        text: 'Talk to Sales',
        href: '/contact',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to <span class="text-accent dark:text-white">Transform</span> Your Business?
    </Fragment>

    <Fragment slot="subtitle">
      Join thousands of companies using CinaGroup solutions. <br class="hidden md:inline" />
      Start your journey today with our free tier.
    </Fragment>
  </CallToAction>
</Layout>
