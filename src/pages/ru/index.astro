---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'CinaGroup — Решения в области ИИ и Web3',
  description: 'CinaGroup предоставляет передовые решения в области ИИ-поиска (CinaSeek), интеллектуальных роботов (CinaClaw), платформы навыков (CinaSkill) и блокчейн-инфраструктуры (CinaChain).',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Добро пожаловать в CinaGroup"
    title={'Построение будущего <span class="text-accent dark:text-white">ИИ и Web3</span>'}
    subtitle="Мы предоставляем передовые решения в области ИИ-поиска, интеллектуальных роботов, платформы навыков и блокчейн-инфраструктуры. Помогаем бизнесу и разработчикам по всему миру."
    actions={[
      {
        variant: 'primary',
        text: 'Наши продукты',
        href: '#business',
        icon: 'tabler:arrow-down',
      },
      { 
        text: 'Контакты', 
        href: '/ru/contact',
        icon: 'tabler:mail',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'AI технологии' 
    }}
  />

  <section id="business" class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Наши направления
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Четыре мощные платформы работают вместе, предоставляя комплексные решения ИИ и Web3
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {['CinaSeek', 'CinaClaw', 'CinaSkill', 'CinaChain'].map((name, i) => (
          <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
            <div class={`absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-${['green', 'orange', 'pink', 'purple'][i]}-400 to-${['green', 'orange', 'pink', 'purple'][i]}-600`}></div>
            <div class="p-6">
              <h3 class="text-xl font-bold dark:text-white mb-2">{name}</h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
                {['Интеллектуальный поиск', 'ИИ-ассистент', 'Платформа навыков', 'Блокчейн-сеть'][i]}
              </p>
              <a href={`/ru/${name.toLowerCase()}`} class={`inline-flex items-center text-${['green', 'orange', 'pink', 'purple'][i]}-600 dark:text-${['green', 'orange', 'pink', 'purple'][i]}-400 font-medium text-sm`}>
                Подробнее
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
