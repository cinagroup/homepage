---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '移动应用落地页',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="移动应用"
    title={'打造您的<span class="text-accent dark:text-white">移动应用</span>'}
    subtitle="快速构建美观、功能强大的移动应用。我们的模板帮助您快速上线，赢得用户。"
    actions={[
      {
        variant: 'primary',
        text: '开始构建',
        href: '/zh/contact',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: '移动应用',
    }}
  />

  <Features
    tagline="核心功能"
    title="为移动而设计"
    subtitle="专为移动应用优化的功能和设计"
    items={[
      {
        title: '响应式设计',
        description: '完美适配各种屏幕尺寸，从手机到平板。',
        icon: 'tabler:device-mobile',
      },
      {
        title: '流畅动画',
        description: '精美的过渡动画，提升用户体验。',
        icon: 'tabler:animation',
      },
      {
        title: '离线支持',
        description: 'PWA 技术支持，离线也能使用核心功能。',
        icon: 'tabler:wifi-off',
      },
    ]}
    columns={3}
  />

  <CallToAction
    tagline="立即开始"
    title="准备好发布您的应用了吗？"
    subtitle="使用我们的模板，快速构建专业移动应用。"
    button={{
      text: '联系我们',
      href: '/zh/contact',
      variant: 'primary',
    }}
  />
</Layout>
