---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'SaaS 落地页',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="SaaS 解决方案"
    title={'构建您的<span class="text-accent dark:text-white">SaaS 产品</span>'}
    subtitle="专为 SaaS 企业设计的落地页模板。展示产品特性，吸引潜在客户，提升转化率。"
    actions={[
      {
        variant: 'primary',
        text: '免费试用',
        href: '/zh/contact',
        icon: 'tabler:rocket',
      },
      {
        text: '查看演示',
        href: '/zh/contact',
        icon: 'tabler:player-play',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'SaaS 产品',
    }}
  />

  <Features
    tagline="产品特性"
    title="专为 SaaS 设计的功能"
    subtitle="展示您的 SaaS 产品优势"
    items={[
      {
        title: '定价展示',
        description: '清晰展示不同方案的价格和功能对比。',
        icon: 'tabler:currency-dollar',
      },
      {
        title: '功能演示',
        description: '交互式演示区域，让用户了解产品如何使用。',
        icon: 'tabler:presentation',
      },
      {
        title: '客户评价',
        description: '展示真实客户反馈，建立信任感。',
        icon: 'tabler:quote',
      },
      {
        title: '数据集成',
        description: '轻松集成分析工具，跟踪转化数据。',
        icon: 'tabler:chart-analytics',
      },
    ]}
    columns={2}
  />

  <CallToAction
    tagline="开始使用"
    title="准备好提升您的 SaaS 业务了吗？"
    subtitle="使用我们的模板，快速构建高转化率的落地页。"
    button={{
      text: '开始构建',
      href: '/zh/contact',
      variant: 'primary',
    }}
  />
</Layout>
