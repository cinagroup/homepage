---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'CinaSeek — AI 智能搜索',
  description: '企业级 AI 搜索解决方案，支持多源数据聚合和自然语言理解',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="智能搜索"
    title={'AI 驱动的<span class="text-green-600 dark:text-green-400">智能搜索</span>'}
    subtitle="CinaSeek 利用先进的人工智能聚合、理解和传递来自多个来源的信息。比以往更快地做出数据驱动的决策。"
    actions={[
      {
        variant: 'primary',
        text: '开始免费试用',
        href: '#pricing',
        icon: 'tabler:rocket',
      },
      { 
        text: '查看演示', 
        href: '#demo',
        icon: 'tabler:player-play',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaSeek AI 搜索' 
    }}
  />

  <!-- Features Section -->
  <Features
    id="features"
    tagline="核心功能"
    title="强大的搜索能力"
    subtitle="构建智能搜索体验所需的一切"
    items={[
      {
        title: '多源数据聚合',
        description: '同时搜索数据库、API、文档和网络来源，提供统一的结果。',
        icon: 'tabler:database-search',
      },
      {
        title: '自然语言理解',
        description: '用普通语言提问。我们的 AI 理解上下文、意图和细微差别。',
        icon: 'tabler:message',
      },
      {
        title: '智能排序和相关性',
        description: '机器学习驱动的排序确保最相关的结果首先出现，并随时间改进。',
        icon: 'tabler:sort-ascending-2',
      },
      {
        title: '实时索引',
        description: '数据变化时自动更新索引，确保搜索结果始终是最新的。',
        icon: 'tabler:refresh',
      },
      {
        title: '高级过滤',
        description: '使用日期、类型、来源和其他元数据精确过滤搜索结果。',
        icon: 'tabler:filter',
      },
      {
        title: '分析仪表板',
        description: '跟踪搜索模式、热门查询和用户行为以优化内容策略。',
        icon: 'tabler:chart-bar',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'CinaSeek 仪表板',
    }}
  />

  <!-- Content Section -->
  <Content
    id="how-it-works"
    tagline="工作原理"
    title="简单三步开始搜索"
    subtitle="无需复杂的设置或漫长的实施周期"
    content="CinaSeek 设计为易于集成和使用。只需连接数据源，配置搜索参数，您的智能搜索就可以运行了。"
    items={[
      {
        title: '连接数据源',
        description: '从数据库、API、云存储或本地文件中添加数据源。',
        icon: 'tabler:plug-connected',
      },
      {
        title: '配置搜索',
        description: '自定义排名规则、过滤选项和 UI 组件以匹配您的需求。',
        icon: 'tabler:settings',
      },
      {
        title: '部署和监控',
        description: '一键部署并实时监控搜索性能和使用情况。',
        icon: 'tabler:rocket',
      },
    ]}
    columns={3}
  />

  <!-- Pricing Section -->
  <Pricing
    id="pricing"
    tagline="定价方案"
    title="简单透明的定价"
    subtitle="选择适合您需求的方案，随时升级"
    prices={[
      {
        title: '入门版',
        subtitle: '适合个人和小团队',
        price: '¥0',
        period: '/月',
        items: [
          {
            title: '最多 10,000 条文档',
            description: '适合小型项目',
          },
          {
            title: '基础 AI 搜索',
            description: '自然语言查询',
          },
          {
            title: '社区支持',
            description: '论坛和文档',
          },
          {
            title: '基础分析',
            description: '搜索量统计',
          },
        ],
        callToAction: {
          text: '免费开始',
          href: '/zh/contact',
          variant: 'secondary',
        },
      },
      {
        title: '专业版',
        subtitle: '适合成长型企业',
        price: '¥999',
        period: '/月',
        hasRibbon: true,
        ribbonTitle: '最受欢迎',
        items: [
          {
            title: '最多 100 万条文档',
            description: '适合中型企业',
          },
          {
            title: '高级 AI 功能',
            description: '上下文理解和智能排序',
          },
          {
            title: '优先支持',
            description: '邮件和聊天支持',
          },
          {
            title: '高级分析',
            description: '详细的使用报告',
          },
          {
            title: '自定义集成',
            description: 'API 访问',
          },
        ],
        callToAction: {
          text: '开始试用',
          href: '/zh/contact',
          variant: 'primary',
        },
      },
      {
        title: '企业版',
        subtitle: '适合大型组织',
        price: '定制',
        period: '',
        items: [
          {
            title: '无限文档',
            description: '无限制扩展',
          },
          {
            title: '定制 AI 模型',
            description: '针对您的领域优化',
          },
          {
            title: '专属支持',
            description: '专属客户经理',
          },
          {
            title: '本地部署选项',
            description: '完全控制数据',
          },
          {
            title: 'SLA 保证',
            description: '99.9% 正常运行时间',
          },
        ],
        callToAction: {
          text: '联系销售',
          href: '/zh/contact',
          variant: 'secondary',
        },
      },
    ]}
  />

  <!-- FAQs Section -->
  <FAQs
    id="faqs"
    tagline="常见问题"
    title="常见问题解答"
    subtitle="查找关于 CinaSeek 的答案"
    items={[
      {
        title: 'CinaSeek 支持哪些数据源？',
        description: 'CinaSeek 支持各种数据源，包括 SQL 和 NoSQL 数据库、REST 和 GraphQL API、云存储（如 AWS S3、阿里云 OSS）、本地文件以及网页。',
      },
      {
        title: '搜索响应速度有多快？',
        description: '典型的搜索查询在 100 毫秒内返回结果。实际性能取决于数据量和查询复杂度。我们提供性能优化建议以确保最佳响应时间。',
      },
      {
        title: '可以自定义搜索结果的外观吗？',
        description: '可以！CinaSeek 提供可定制的 UI 组件，您可以完全控制搜索结果的样式和布局。我们还提供 API 以便完全自定义前端。',
      },
      {
        title: '提供数据安全和隐私保护吗？',
        description: '是的，安全性是我们的首要任务。CinaSeek 提供传输和静态加密、基于角色的访问控制、审计日志，并符合 GDPR 和其他数据保护法规。',
      },
      {
        title: '如何开始使用？',
        description: '只需注册免费账户，连接您的第一个数据源，几分钟内就可以开始搜索。我们的入门指南和示例代码将帮助您快速上手。',
      },
    ]}
    columns={1}
  />

  <!-- CTA Section -->
  <CallToAction
    id="cta"
    tagline="开始使用"
    title="准备好提升您的搜索体验了吗？"
    subtitle="加入数千家使用 CinaSeek 构建智能搜索应用的公司。"
    button={{
      text: '开始免费试用',
      href: '/zh/contact',
      variant: 'primary',
      icon: 'tabler:rocket',
    }}
  />
</Layout>
