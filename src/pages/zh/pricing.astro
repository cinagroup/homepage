---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '定价方案',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget -->
  <HeroText
    tagline="定价方案"
    title="适合每个团队的灵活定价"
    subtitle="选择最适合您需求的方案"
  />

  <!-- Pricing Widget -->
  <Prices
    title="我们的价格"
    subtitle="只为所需付费"
    prices={[
      {
        title: '基础版',
        subtitle: '适合个人使用',
        price: 99,
        period: '元/月',
        items: [
          {
            description: '最多 10,000 条数据',
          },
          {
            description: '基础 AI 功能',
          },
          {
            description: '社区支持',
          },
          {
            description: '基础分析报告',
          },
        ],
        callToAction: {
          target: '_blank',
          text: '免费试用',
          href: '/zh/contact',
        },
      },
      {
        title: '专业版',
        subtitle: '适合小型团队',
        price: 599,
        period: '元/月',
        items: [
          {
            description: '最多 100 万条数据',
          },
          {
            description: '高级 AI 功能',
          },
          {
            description: '优先邮件支持',
          },
          {
            description: '详细分析报告',
          },
          {
            description: 'API 访问权限',
          },
        ],
        callToAction: {
          target: '_blank',
          text: '开始试用',
          href: '/zh/contact',
        },
        hasRibbon: true,
        ribbonTitle: '最受欢迎',
      },
      {
        title: '企业版',
        subtitle: '适合大型企业',
        price: '定制',
        period: '',
        items: [
          {
            description: '无限数据量',
          },
          {
            description: '定制 AI 模型',
          },
          {
            description: '专属客户经理',
          },
          {
            description: '私有化部署',
          },
          {
            description: 'SLA 服务保障',
          },
        ],
        callToAction: {
          target: '_blank',
          text: '联系销售',
          href: '/zh/contact',
        },
      },
    ]}
  />

  <!-- FAQs Widget -->
  <FAQs
    tagline="常见问题"
    title="常见问题解答"
    subtitle="查找您需要的答案"
    items={[
      {
        title: '如何开始使用？',
        description: '只需注册账户，选择适合的方案，即可立即开始使用我们的服务。我们提供详细的使用指南和示例代码帮助您快速上手。',
      },
      {
        title: '可以随时升级或降级方案吗？',
        description: '可以，您可以随时在账户设置中调整方案。升级立即生效，降级将在下个计费周期生效。',
      },
      {
        title: '支持哪些付款方式？',
        description: '我们支持支付宝、微信支付、银行转账等多种付款方式。企业客户还可以选择季度或年度付款。',
      },
      {
        title: '有退款政策吗？',
        description: '我们提供 7 天无理由退款保证。如果您对服务不满意，可在购买后 7 天内申请全额退款。',
      },
      {
        title: '提供发票吗？',
        description: '是的，我们为所有付费客户提供正规增值税发票。可在账户设置中申请电子发票或纸质发票。',
      },
    ]}
    columns={1}
  />

  <!-- CTA Section -->
  <CallToAction
    tagline="开始使用"
    title="准备好开始了吗？"
    subtitle="立即注册，享受 14 天免费试用"
    button={{
      text: '免费试用',
      href: '/zh/contact',
      variant: 'primary',
      icon: 'tabler:rocket',
    }}
  />
</Layout>
