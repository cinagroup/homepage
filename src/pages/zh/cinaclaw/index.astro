---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'CinaClaw — 24/7 AI 智能助手',
  description: '全天候 AI 助手，支持多平台集成和工作流自动化',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="AI 助手"
    title={'您的<span class="text-orange-600 dark:text-orange-400">24/7 智能助手</span>'}
    subtitle="CinaClaw 是一个强大的 AI 助手，可帮助您自动化任务、回答问题并提高工作效率。支持多平台集成，随时随地为您服务。"
    actions={[
      {
        variant: 'primary',
        text: '免费试用',
        href: '#pricing',
        icon: 'tabler:rocket',
      },
      { 
        text: '观看演示', 
        href: '#demo',
        icon: 'tabler:player-play',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1531746790731-6c087fecd65a?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaClaw AI 助手' 
    }}
  />

  <!-- Features Section -->
  <Features
    id="features"
    tagline="核心功能"
    title="强大的 AI 助手能力"
    subtitle="自动化日常工作，专注于重要事务"
    items={[
      {
        title: '智能对话',
        description: '自然语言对话，理解上下文，提供准确有用的回答。',
        icon: 'tabler:message-chatbot',
      },
      {
        title: '多平台集成',
        description: '与企业微信、钉钉、Slack、Telegram 等平台无缝集成。',
        icon: 'tabler:brand-slack',
      },
      {
        title: '工作流自动化',
        description: '自动执行重复性任务，如数据录入、报告生成、提醒发送等。',
        icon: 'tabler:workflow',
      },
      {
        title: '知识库',
        description: '连接您的文档和知识库，提供基于企业内部信息的回答。',
        icon: 'tabler:database',
      },
      {
        title: '多语言支持',
        description: '支持中文、英文等多种语言，满足全球化团队需求。',
        icon: 'tabler:world',
      },
      {
        title: '数据分析',
        description: '跟踪使用情况、热门问题和用户满意度，持续优化服务。',
        icon: 'tabler:chart-analytics',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1531482615713-2afd69097998?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'CinaClaw 工作界面',
    }}
  />

  <!-- Content Section -->
  <Content
    id="use-cases"
    tagline="应用场景"
    title="适用于各种业务场景"
    subtitle="从客户服务到内部协作，CinaClaw 都能发挥作用"
    content="无论您是初创公司还是大型企业，CinaClaw 都能帮助您提高效率、降低成本、提升用户体验。"
    items={[
      {
        title: '客户服务',
        description: '7x24 小时自动回答客户问题，处理常见咨询，转接人工客服。',
        icon: 'tabler:headset',
      },
      {
        title: '内部支持',
        description: '帮助员工解答 HR、IT、财务等常见问题，减轻行政部门负担。',
        icon: 'tabler:users',
      },
      {
        title: '销售辅助',
        description: '为销售团队提供产品信息、价格查询、订单跟踪等支持。',
        icon: 'tabler:briefcase',
      },
      {
        title: '培训学习',
        description: '作为智能导师，帮助新员工快速学习公司流程和业务知识。',
        icon: 'tabler:book',
      },
    ]}
    columns={2}
    isReversed={true}
  />

  <!-- Pricing Section -->
  <Pricing
    id="pricing"
    tagline="定价方案"
    title="灵活的定价方案"
    subtitle="根据您的团队规模选择合适方案"
    prices={[
      {
        title: '免费版',
        subtitle: '个人和小型团队',
        price: '¥0',
        period: '/月',
        items: [
          {
            title: '每月 1,000 次对话',
            description: '适合个人使用',
          },
          {
            title: '基础 AI 功能',
            description: '标准对话能力',
          },
          {
            title: '社区支持',
            description: '论坛和文档',
          },
          {
            title: '1 个集成平台',
            description: '选择 1 个平台',
          },
        ],
        callToAction: {
          text: '免费开始',
          href: '/zh/contact',
          variant: 'secondary',
        },
      },
      {
        title: '团队版',
        subtitle: '成长型团队',
        price: '¥599',
        period: '/月',
        hasRibbon: true,
        ribbonTitle: '最受欢迎',
        items: [
          {
            title: '每月 10 万次对话',
            description: '适合中小团队',
          },
          {
            title: '高级 AI 功能',
            description: '自定义知识库',
          },
          {
            title: '优先支持',
            description: '邮件和聊天',
          },
          {
            title: '5 个集成平台',
            description: '多平台支持',
          },
          {
            title: '使用分析',
            description: '详细报告',
          },
        ],
        callToAction: {
          text: '开始试用',
          href: '/zh/contact',
          variant: 'primary',
        },
      },
      {
        title: '企业版',
        subtitle: '大型组织',
        price: '定制',
        period: '',
        items: [
          {
            title: '无限对话',
            description: '无限制使用',
          },
          {
            title: '定制 AI 模型',
            description: '专属训练',
          },
          {
            title: '专属支持',
            description: '客户经理',
          },
          {
            title: '无限集成',
            description: '所有平台',
          },
          {
            title: '私有部署',
            description: '数据安全',
          },
        ],
        callToAction: {
          text: '联系销售',
          href: '/zh/contact',
          variant: 'secondary',
        },
      },
    ]}
  />

  <!-- CTA Section -->
  <CallToAction
    id="cta"
    tagline="立即开始"
    title="准备好提升工作效率了吗？"
    subtitle="让 CinaClaw 成为您的智能助手，释放团队潜力。"
    button={{
      text: '免费试用',
      href: '/zh/contact',
      variant: 'primary',
      icon: 'tabler:rocket',
    }}
  />
</Layout>
