---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Form from '~/components/ui/Form.astro';

const metadata = {
  title: '联系我们 — 获取帮助',
  description: '有问题吗？我们很乐意听取您的意见。给我们发送消息，我们会尽快回复。',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="联系我们"
    title={'让我们<span class="text-accent dark:text-white">开始对话</span>'}
    subtitle="对我们的产品有疑问？需要集成帮助？我们随时为您服务！"
    image={{ 
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: '联系我们' 
    }}
  />

  <!-- Contact Form Section -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Contact Information -->
        <div>
          <h2 class="text-3xl font-bold dark:text-white mb-6">联系方式</h2>
          <p class="text-gray-600 dark:text-gray-300 mb-8">
            填写表单，我们的团队将在 24 小时内回复您。
          </p>

          <div class="space-y-6">
            <!-- Email -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">发送电子邮件</h3>
                <p class="text-gray-600 dark:text-gray-300">info@cinagroup.com</p>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">我们将在 24 小时内回复</p>
              </div>
            </div>

            <!-- TikTok -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-black dark:bg-gray-600 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-white dark:text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">关注 TikTok</h3>
                <p class="text-gray-600 dark:text-gray-300">最新更新和教程</p>
                <a href="https://tiktok.com/@cinaseek" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline text-sm mt-1 inline-block">tiktok.com/@cinaseek →</a>
              </div>
            </div>

            <!-- X (Twitter) -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-black dark:bg-gray-600 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-white dark:text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M13.6823 10.6218L20.2391 3H18.6854L12.9921 9.61788L8.44486 3H3.2002L10.0765 13.0074L3.2002 21H4.75404L10.7663 14.0113L15.5685 21H20.8131L13.6819 10.6218H13.6823ZM11.5541 13.0956L10.8574 12.0991L5.31391 4.16971H7.70053L12.1742 10.5689L12.8709 11.5655L18.6861 19.8835H16.2995L11.5541 13.096V13.0956Z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">关注 X</h3>
                <p class="text-gray-600 dark:text-gray-300">@CinaGroup</p>
                <a href="https://x.com/cinagroup" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline text-sm mt-1 inline-block">x.com/cinagroup →</a>
              </div>
            </div>

            <!-- Office -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">我们的办公室</h3>
                <p class="text-gray-600 dark:text-gray-300">北京市海淀区中关村大街 1 号</p>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">创新大厦 A 座 10 层</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-8">
          <h2 class="text-2xl font-bold dark:text-white mb-6">发送消息</h2>
          <Form
            inputs={[
              {
                type: 'text',
                name: 'name',
                label: '姓名',
                placeholder: '您的姓名',
                autocomplete: 'name',
              },
              {
                type: 'email',
                name: 'email',
                label: '电子邮件',
                placeholder: 'your@email.com',
                autocomplete: 'email',
              },
              {
                type: 'text',
                name: 'company',
                label: '公司',
                placeholder: '公司名称（选填）',
              },
            ]}
            textarea={{
              label: '消息',
              name: 'message',
              placeholder: '请告诉我们您想了解什么...',
              rows: 5,
            }}
            button="发送消息"
            description="我们将在 24 小时内回复您。"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold dark:text-white mb-4">常见问题</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">快速找到您需要的答案</p>
      </div>
      <div class="max-w-3xl mx-auto space-y-4">
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <h3 class="font-bold dark:text-white mb-2">回复时间通常是多久？</h3>
          <p class="text-gray-600 dark:text-gray-300">我们承诺在 24 小时内回复所有咨询。紧急问题请拨打我们的客服热线。</p>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <h3 class="font-bold dark:text-white mb-2">有技术支持吗？</h3>
          <p class="text-gray-600 dark:text-gray-300">是的，我们为所有企业客户提供专业技术支持服务，包括 API 集成指导和定制开发咨询。</p>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <h3 class="font-bold dark:text-white mb-2">可以预约产品演示吗？</h3>
          <p class="text-gray-600 dark:text-gray-300">当然可以！请在表单中注明您感兴趣的产品，我们会安排专业的产品顾问为您演示。</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
