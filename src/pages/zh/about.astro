---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '关于我们 — CinaGroup',
  description: '了解 CinaGroup 致力于让每个人都能使用 AI 和 Web3 技术的使命。',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="关于我们"
    title={'构建<span class="text-accent dark:text-white">技术的未来</span>'}
    subtitle="我们致力于让 AI 和 Web3 技术变得人人可及、负担得起、实用有用。"
    image={{ 
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaGroup 团队' 
    }}
  />

  <!-- Mission Section -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold dark:text-white mb-6">我们的使命</h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
          "让 AI 和 Web3 技术民主化，使每个人都能轻松获取、负担得起并从中受益。"
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
          <div class="p-6 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
            <div class="text-4xl mb-4">🎯</div>
            <h3 class="font-bold dark:text-white mb-2">可及性</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              打破技术壁垒，让任何人都能利用尖端技术
            </p>
          </div>
          <div class="p-6 bg-green-50 dark:bg-green-900/20 rounded-xl">
            <div class="text-4xl mb-4">💰</div>
            <h3 class="font-bold dark:text-white mb-2">可负担</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              提供适合所有人的企业级解决方案价格
            </p>
          </div>
          <div class="p-6 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
            <div class="text-4xl mb-4">⚡</div>
            <h3 class="font-bold dark:text-white mb-2">实用性</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              构建解决实际问题的实用工具
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
        <div>
          <h2 class="text-3xl font-bold dark:text-white mb-6">我们的故事</h2>
          <div class="space-y-4 text-gray-600 dark:text-gray-300">
            <p>
              CinaGroup 成立于 2024 年，源于一个简单的观察：虽然 AI 和区块链技术正在快速发展，但它们对大多数人和企业来说仍然难以企及。
            </p>
            <p>
              我们的创始人团队来自领先科技公司，他们决心改变这一现状。他们相信，这些变革性技术的好处应该惠及每个人，而不仅仅是资金雄厚的大型企业。
            </p>
            <p>
              今天，我们为全球超过 50,000 名用户提供服务，从独立开发者到财富 500 强公司。我们的四条产品线——CinaSeek、CinaClaw、CinaSkill 和 CinaChain——共同构成了一个全面的 AI 和 Web3 解决方案生态系统。
            </p>
          </div>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-2xl p-8 shadow-xl">
          <div class="space-y-6">
            <div class="flex items-center">
              <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                2024
              </div>
              <div class="ml-6">
                <h3 class="font-bold dark:text-white">公司成立</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">中国北京</p>
              </div>
            </div>
            <div class="flex items-center">
              <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                2025
              </div>
              <div class="ml-6">
                <h3 class="font-bold dark:text-white">产品发布</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">CinaSeek 和 CinaClaw 上线</p>
              </div>
            </div>
            <div class="flex items-center">
              <div class="w-16 h-16 bg-purple-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                2026
              </div>
              <div class="ml-6">
                <h3 class="font-bold dark:text-white">全球扩展</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">服务 50,000+ 用户</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold dark:text-white mb-4">我们的价值观</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">指导我们每一天工作的核心原则</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="font-bold dark:text-white mb-2">用户至上</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm">用户需求是我们一切决策的核心</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">💡</div>
          <h3 class="font-bold dark:text-white mb-2">持续创新</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm">不断突破技术边界，追求卓越</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🔒</div>
          <h3 class="font-bold dark:text-white mb-2">诚信透明</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm">以诚信为本，保持开放透明</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🌍</div>
          <h3 class="font-bold dark:text-white mb-2">全球视野</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm">服务全球用户，拥抱多元文化</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold dark:text-white mb-4">领导团队</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">经验丰富的行业专家引领公司前进</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="bg-white dark:bg-gray-700 rounded-xl overflow-hidden shadow-lg">
          <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600"></div>
          <div class="p-6">
            <h3 class="font-bold text-xl dark:text-white">张伟</h3>
            <p class="text-blue-600 dark:text-blue-400 text-sm mb-3">创始人 & CEO</p>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              前阿里巴巴 AI 实验室负责人，15 年人工智能和云计算经验
            </p>
          </div>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl overflow-hidden shadow-lg">
          <div class="h-48 bg-gradient-to-br from-green-400 to-green-600"></div>
          <div class="p-6">
            <h3 class="font-bold text-xl dark:text-white">李明</h3>
            <p class="text-green-600 dark:text-green-400 text-sm mb-3">联合创始人 & CTO</p>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              前腾讯区块链首席架构师，分布式系统专家
            </p>
          </div>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl overflow-hidden shadow-lg">
          <div class="h-48 bg-gradient-to-br from-purple-400 to-purple-600"></div>
          <div class="p-6">
            <h3 class="font-bold text-xl dark:text-white">王芳</h3>
            <p class="text-purple-600 dark:text-purple-400 text-sm mb-3">首席产品官</p>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              前字节跳动产品总监，10 年互联网产品经验
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CallToAction
    title="加入我们，共创未来"
    subtitle="无论您是求职者、合作伙伴还是投资者，我们都欢迎您的加入。"
    button={{
      text: '联系我们',
      href: '/zh/contact',
      variant: 'primary',
    }}
  />
</Layout>
