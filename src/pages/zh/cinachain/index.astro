---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'CinaChain — 高性能区块链网络',
  description: '高性能、低成本的 Web3 基础设施，支持智能合约和 DeFi',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="区块链网络"
    title={'下一代<span class="text-purple-600 dark:text-purple-400">Web3 基础设施</span>'}
    subtitle="CinaChain 是一个高性能、低成本的区块链网络，支持智能合约、DeFi 应用和 NFT。为企业和开发者提供可靠的 Web3 基础设施。"
    actions={[
      {
        variant: 'primary',
        text: '开始构建',
        href: '#developers',
        icon: 'tabler:code',
      },
      { 
        text: '查看文档', 
        href: '#docs',
        icon: 'tabler:file-text',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1639762681485-074b7f938ba0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaChain 区块链' 
    }}
  />

  <!-- Features Section -->
  <Features
    id="features"
    tagline="核心优势"
    title="为什么选择 CinaChain"
    subtitle="为大规模应用而设计的区块链网络"
    items={[
      {
        title: '高性能',
        description: '每秒 10,000+ 交易处理速度，满足企业级应用需求。',
        icon: 'tabler:zap',
      },
      {
        title: '低成本',
        description: '交易费用低于 $0.01，让 DApp 使用更加经济。',
        icon: 'tabler:coin',
      },
      {
        title: 'EVM 兼容',
        description: '完全兼容以太坊虚拟机，轻松迁移现有 DApp。',
        icon: 'tabler:box',
      },
      {
        title: '跨链互操作',
        description: '支持与其他主流区块链的资产和数据互操作。',
        icon: 'tabler:link',
      },
      {
        title: '企业级安全',
        description: 'PoS 共识机制，经过审计的智能合约，确保资产安全。',
        icon: 'tabler:shield-lock',
      },
      {
        title: '开发者友好',
        description: '完善的 SDK、文档和工具，降低开发门槛。',
        icon: 'tabler:tools',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1621504450168-b8c43753612b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'CinaChain 网络',
    }}
  />

  <!-- Content Section -->
  <Content
    id="ecosystem"
    tagline="生态系统"
    title="丰富的 DApp 生态"
    subtitle="从 DeFi 到 NFT，探索 CinaChain 上的无限可能"
    content="CinaChain 生态系统正在快速增长，已有数百个 DApp 在网络上运行，涵盖 DeFi、NFT、游戏、社交等多个领域。"
    items={[
      {
        title: 'DeFi 协议',
        description: '去中心化交易所、借贷平台、收益农场等金融应用。',
        icon: 'tabler:currency-dollar',
      },
      {
        title: 'NFT 市场',
        description: '数字艺术品、收藏品、游戏道具的铸造和交易平台。',
        icon: 'tabler:photo',
      },
      {
        title: '链游',
        description: '基于区块链的游戏，真正的数字资产所有权。',
        icon: 'tabler:gamepad',
      },
      {
        title: '社交 DApp',
        description: '去中心化社交网络，用户掌握自己的数据。',
        icon: 'tabler:users',
      },
    ]}
    columns={2}
  />

  <!-- Network Stats -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold dark:text-white mb-4">网络数据</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">实时了解 CinaChain 网络状态</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center p-6 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-3xl font-bold text-purple-600 dark:text-purple-400 mb-2">500+</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">验证节点</div>
        </div>
        <div class="text-center p-6 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-3xl font-bold text-purple-600 dark:text-purple-400 mb-2">10M+</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">总交易数</div>
        </div>
        <div class="text-center p-6 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-3xl font-bold text-purple-600 dark:text-purple-400 mb-2">300K+</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">活跃地址</div>
        </div>
        <div class="text-center p-6 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-3xl font-bold text-purple-600 dark:text-purple-400 mb-2">$0.005</div>
          <div class="text-sm text-gray-600 dark:text-gray-400">平均 Gas 费</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Developer Resources -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold dark:text-white mb-4">开发者资源</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">快速开始构建 DApp</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="font-bold dark:text-white mb-2 text-xl">开发文档</h3>
          <p class="text-gray-600 dark:text-gray-300 mb-4">详细的 API 文档、教程和最佳实践指南。</p>
          <a href="#" class="text-purple-600 dark:text-purple-400 hover:underline text-sm">查看文档 →</a>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="font-bold dark:text-white mb-2 text-xl">代码示例</h3>
          <p class="text-gray-600 dark:text-gray-300 mb-4">丰富的代码示例和模板，快速上手开发。</p>
          <a href="#" class="text-purple-600 dark:text-purple-400 hover:underline text-sm">浏览示例 →</a>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="font-bold dark:text-white mb-2 text-xl">开发者社区</h3>
          <p class="text-gray-600 dark:text-gray-300 mb-4">加入开发者社区，交流经验和获取支持。</p>
          <a href="#" class="text-purple-600 dark:text-purple-400 hover:underline text-sm">加入社区 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CallToAction
    id="cta"
    tagline="开始构建"
    title="准备好构建下一代 DApp 了吗？"
    subtitle="加入 CinaChain 生态系统，开启 Web3 之旅。"
    button={{
      text: '开始构建',
      href: '/zh/contact',
      variant: 'primary',
      icon: 'tabler:rocket',
    }}
  />
</Layout>
