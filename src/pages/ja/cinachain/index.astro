---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'CinaChain — 高性能ブロックチェーンネットワーク',
  description: '高性能、低コストの Web3 インフラ。スマートコントラクトと DeFi をサポート。',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="ブロックチェーンネットワーク"
    title={'次世代<span class="text-purple-600 dark:text-purple-400">Web3 インフラ</span>'}
    subtitle="CinaChain は、スマートコントラクト、DeFi アプリケーション、NFT をサポートする高性能、低コストのブロックチェーンネットワークです。"
    actions={[
      { variant: 'primary', text: '構築を開始', href: '/ja/contact', icon: 'tabler:code' },
      { text: 'ドキュメント', href: '/ja/contact', icon: 'tabler:file-text' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1639762681485-074b7f938ba0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'CinaChain' }}
  />

  <Features
    tagline="コアメリット"
    title="CinaChain を選ぶ理由"
    subtitle="大規模アプリケーション向けに設計されたブロックチェーンネットワーク"
    items={[
      { title: '高性能', description: '秒間 10,000+ トランザクション処理速度、企業レベルのアプリケーションニーズに対応', icon: 'tabler:bolt' },
      { title: '低コスト', description: 'トランザクション手数料 0.01 ドル未満、DApp の使用を経済的に', icon: 'tabler:coin' },
      { title: 'EVM 互換', description: 'イーサリアム仮想マシンと完全互換、既存の DApp を簡単に移行', icon: 'tabler:box' },
      { title: 'クロスチェーン相互運用', description: '他の主要ブロックチェーンとの資産およびデータ相互運用をサポート', icon: 'tabler:link' },
      { title: '企業レベルのセキュリティ', description: 'PoS コンセンサスメカニズム、監査済みのスマートコントラクト、資産の安全を確保', icon: 'tabler:shield-lock' },
      { title: '開発者フレンドリー', description: '包括的な SDK、ドキュメント、ツール、開発のハードルを低減', icon: 'tabler:tools' },
    ]}
    columns={3}
    image={{ src: 'https://images.unsplash.com/photo-1621504450168-b8c43753612b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Network' }}
  />

  <CallToAction
    tagline="構築を開始"
    title="次世代 DApp を構築する準備はできましたか？"
    subtitle="CinaChain エコシステムに参加し、Web3 の旅を始めましょう。"
    button={{ text: '構築を開始', href: '/ja/contact', variant: 'primary', icon: 'tabler:rocket' }}
  />
</Layout>
