---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = { title: 'お問い合わせ — CinaGroup' };
---
<Layout metadata={metadata}>
  <Hero tagline="お問い合わせ" title={'<span class="text-accent dark:text-white">ご相談</span> をお待ちしております'} subtitle="ご質問がありますか？お気軽にお問い合わせください。24 時間以内にご返信いたします。" image={{ src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Contact' }} />
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold dark:text-white mb-6">連絡先</h2>
      <p class="text-gray-600 dark:text-gray-300 mb-8">メール：info@cinagroup.com</p>
      <p class="text-gray-600 dark:text-gray-300">住所：北京市海淀区中関村大街 1 号</p>
    </div>
  </section>
</Layout>
