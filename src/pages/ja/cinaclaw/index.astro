---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'CinaClaw — 24 時間 365 日 AI アシスタント',
  description: 'マルチプラットフォーム統合とワークフロー自動化をサポートする AI アシスタント',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="AI アシスタント"
    title={'あなたの<span class="text-orange-600 dark:text-orange-400">24 時間 365 日スマートアシスタント</span>'}
    subtitle="CinaClaw は、タスクの自動化、質問への回答、生産性の向上を支援する強力な AI アシスタントです。"
    actions={[
      { variant: 'primary', text: '無料トライアル', href: '/ja/contact', icon: 'tabler:rocket' },
      { text: 'デモを見る', href: '/ja/contact', icon: 'tabler:player-play' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1531746790731-6c087fecd65a?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'CinaClaw' }}
  />

  <Features
    tagline="主な機能"
    title="強力な AI アシスタント機能"
    subtitle="日常業務を自動化し、重要なことに集中"
    items={[
      { title: 'スマート対話', description: '自然言語での対話、文脈を理解し、正確で有用な回答を提供', icon: 'tabler:message-chatbot' },
      { title: 'マルチプラットフォーム', description: '企業微信、釘釘、Slack、Telegram などとシームレスに統合', icon: 'tabler:brand-slack' },
      { title: 'ワークフロー自動化', description: 'データ入力、レポート生成、リマインダー送信などの反復タスクを自動実行', icon: 'tabler:refresh' },
      { title: 'ナレッジベース', description: 'ドキュメントやナレッジベースを接続し、企業情報に基づく回答を提供', icon: 'tabler:database' },
      { title: '多言語サポート', description: '中国語、英語、日本語など複数言語に対応', icon: 'tabler:world' },
      { title: 'データ分析', description: '使用状況、人気質問、ユーザー満足度を追跡し、サービスを継続的に最適化', icon: 'tabler:chart-analytics' },
    ]}
    columns={3}
    image={{ src: 'https://images.unsplash.com/photo-1531482615713-2afd69097998?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Dashboard' }}
  />

  <CallToAction
    tagline="今すぐ開始"
    title="工作效率を向上させる準備はできましたか？"
    subtitle="CinaClaw をスマートアシスタントとして活用し、チームの潜在能力を解放しましょう。"
    button={{ text: '無料トライアル', href: '/ja/contact', variant: 'primary', icon: 'tabler:rocket' }}
  />
</Layout>
