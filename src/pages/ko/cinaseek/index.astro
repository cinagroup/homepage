---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'CinaSeek — AI 지능형 검색',
  description: 'AI 기반 기업 검색 솔루션. 다중 소스 데이터 집계 및 자연어 이해 지원',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="지능형 검색"
    title={'AI 기반의 <span class="text-green-600 dark:text-green-400">스마트 검색</span>'}
    subtitle="CinaSeek 는 고급 AI 를 활용하여 여러 소스에서 정보를 집계, 이해, 제공합니다. 데이터 기반 의사 결정을 그 어느 때보다 빠르게."
    actions={[
      { variant: 'primary', text: '무료 체험 시작', href: '/ko/contact', icon: 'tabler:rocket' },
      { text: '데모 보기', href: '/ko/contact', icon: 'tabler:player-play' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'CinaSeek' }}
  />

  <Features
    tagline="주요 기능"
    title="강력한 검색 기능"
    subtitle="지능형 검색 경험을 구축하는 데 필요한 모든 것"
    items={[
      { title: '다중 소스 집계', description: '데이터베이스, API, 문서, 웹 소스를 동시에 검색하여 통합 결과 제공', icon: 'tabler:database-search' },
      { title: '자연어 이해', description: '일반적인 언어로 질문하세요. AI 가 문맥, 의도, 뉘앙스를 이해합니다', icon: 'tabler:message' },
      { title: '스마트 순위', description: 'ML 기반 순위로 가장 관련성 높은 결과를 먼저 표시', icon: 'tabler:sort-ascending-2' },
      { title: '실시간 인덱스', description: '데이터 변경 시 자동으로 인덱스 업데이트', icon: 'tabler:refresh' },
      { title: '고급 필터링', description: '날짜, 유형, 소스 및 기타 메타데이터로 검색 결과 정확히 필터링', icon: 'tabler:filter' },
      { title: '분석 대시보드', description: '검색 패턴, 인기 쿼리, 사용자 행동 추적', icon: 'tabler:chart-bar' },
    ]}
    columns={3}
    image={{ src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Dashboard' }}
  />

  <CallToAction
    tagline="지금 시작"
    title="검색 경험을 향상시킬 준비가 되셨나요?"
    subtitle="수천 개의 기업이 CinaSeek 를 사용하고 있습니다."
    button={{ text: '무료로 시작', href: '/ko/contact', variant: 'primary', icon: 'tabler:rocket' }}
  />
</Layout>
