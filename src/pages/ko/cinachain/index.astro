---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'CinaChain — 고성능 블록체인 네트워크',
  description: '고성능, 저비용의 Web3 인프라. 스마트 컨트랙트 및 DeFi 지원.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="블록체인 네트워크"
    title={'차세대 <span class="text-purple-600 dark:text-purple-400">Web3 인프라</span>'}
    subtitle="CinaChain 은 스마트 컨트랙트, DeFi 애플리케이션, NFT 를 지원하는 고성능, 저비용 블록체인 네트워크입니다."
    actions={[
      { variant: 'primary', text: '구축 시작', href: '/ko/contact', icon: 'tabler:code' },
      { text: '문서 보기', href: '/ko/contact', icon: 'tabler:file-text' },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1639762681485-074b7f938ba0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'CinaChain' }}
  />

  <Features
    tagline="핵심 이점"
    title="CinaChain 을 선택하는 이유"
    subtitle="대규모 애플리케이션을 위해 설계된 블록체인 네트워크"
    items={[
      { title: '고성능', description: '초당 10,000+ 트랜잭션 처리 속도, 기업 수준 애플리케이션 요구 충족', icon: 'tabler:bolt' },
      { title: '저비용', description: '트랜잭션 수수료 $0.01 미만, DApp 사용 경제적', icon: 'tabler:coin' },
      { title: 'EVM 호환', description: '이더리움 가상 머신과 완전 호환, 기존 DApp 쉽게 이전', icon: 'tabler:box' },
      { title: '크로스체인 상호운용', description: '다른 주요 블록체인과의 자산 및 데이터 상호운용 지원', icon: 'tabler:link' },
      { title: '기업 수준 보안', description: 'PoS 합의 메커니즘, 감사된 스마트 컨트랙트, 자산 안전 보장', icon: 'tabler:shield-lock' },
      { title: '개발자 친화적', description: '포괄적인 SDK, 문서, 도구, 개발 장벽 낮춤', icon: 'tabler:tools' },
    ]}
    columns={3}
    image={{ src: 'https://images.unsplash.com/photo-1621504450168-b8c43753612b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Network' }}
  />

  <CallToAction
    tagline="구축 시작"
    title="차세대 DApp 을 구축할 준비가 되셨나요?"
    subtitle="CinaChain 생태계에 참여하여 Web3 여정을 시작하세요."
    button={{ text: '구축 시작', href: '/ko/contact', variant: 'primary', icon: 'tabler:rocket' }}
  />
</Layout>
