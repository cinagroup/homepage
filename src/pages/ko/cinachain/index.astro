---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = { title: 'CinaGroup 제품' };
---
<Layout metadata={metadata}>
  <Hero tagline="제품" title={'<span class="text-accent dark:text-white">스마트 솔루션</span>'} subtitle="비즈니스 성장을 위한 강력한 도구" actions={[{ variant: 'primary', text: '무료 시작', href: '/ko/contact', icon: 'tabler:rocket' }]} image={{ src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Product' }} />
  <Features tagline="주요 기능" title="강력한 기능" subtitle="비즈니스 성공 지원" items={[{ title: '고성능', description: '빠르고 안정적인 처리', icon: 'tabler:zap' }, { title: '쉬운 통합', description: '기존 시스템과 원활하게 연동', icon: 'tabler:plug-connected' }, { title: '24/7 지원', description: '연중무휴 지원 체계', icon: 'tabler:headset' }]} columns={3} />
  <CallToAction tagline="지금 시작" title="준비되셨나요?" subtitle="14 일 무료 체험" button={{ text: '무료 시작', href: '/ko/contact', variant: 'primary', icon: 'tabler:rocket' }} />
</Layout>
