---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = { title: '문의하기 — CinaGroup' };
---
<Layout metadata={metadata}>
  <Hero tagline="문의하기" title={'<span class="text-accent dark:text-white">문의</span> 를 기다립니다'} subtitle="질문이 있으신가요? 언제든지 문의하십시오. 24 시간 이내에 답변드리겠습니다." image={{ src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Contact' }} />
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold dark:text-white mb-6">연락처</h2>
      <p class="text-gray-600 dark:text-gray-300 mb-8">이메일：info@cinagroup.com</p>
      <p class="text-gray-600 dark:text-gray-300">주소：北京市海澱区中関村大街 1 号</p>
    </div>
  </section>
</Layout>
