---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';

const metadata = {
  title: 'CinaClaw — Intelligent AI Assistant & Automation Robot',
  description: '7x24 AI assistant with multi-platform integration for QQ, WeChat, Telegram, Discord and more',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->
  <Hero
    tagline="AI Assistant"
    title={'Your <span class="text-orange-600 dark:text-orange-400">24/7 AI Assistant</span>'}
    subtitle="CinaClaw is an intelligent automation robot that integrates with your favorite platforms. Automate tasks, engage users, and boost productivity."
    actions={[
      {
        variant: 'primary',
        text: 'Try Demo',
        href: '#demo',
        icon: 'tabler:player-play',
      },
      { 
        text: 'View Pricing', 
        href: '#pricing',
        icon: 'tabler:currency-dollar',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaClaw AI Robot' 
    }}
  />

  <!-- Features Section *************** -->
  <Features
    id="features"
    tagline="Core Features"
    title="Intelligent Automation Capabilities"
    subtitle="Everything you need to automate workflows and engage users"
    items={[
      {
        title: 'Multi-Platform Integration',
        description: 'Seamlessly connect with QQ, WeChat, Telegram, Discord, Slack, and more. One bot, everywhere.',
        icon: 'tabler:brand-telegram',
      },
      {
        title: 'Natural Language Conversations',
        description: 'Advanced NLP enables human-like conversations. Context-aware responses that understand nuance.',
        icon: 'tabler:message',
      },
      {
        title: 'Task Automation',
        description: 'Automate repetitive tasks: reminders, notifications, data collection, scheduling, and more.',
        icon: 'tabler:robot',
      },
      {
        title: 'Custom Skills',
        description: 'Extend functionality with custom skills from CinaSkill marketplace or build your own.',
        icon: 'tabler:puzzle',
      },
      {
        title: 'Smart Reminders & Monitoring',
        description: 'Set up scheduled tasks, monitoring alerts, and proactive notifications based on triggers.',
        icon: 'tabler:bell-ringing',
      },
      {
        title: 'Analytics Dashboard',
        description: 'Track conversations, user engagement, task completion rates, and bot performance metrics.',
        icon: 'tabler:chart-line',
      },
    ]}
  />

  <!-- Use Cases ******************** -->
  <Content
    isReversed
    tagline="Use Cases"
    title="Powerful Applications"
    items={[
      {
        title: 'Customer Service',
        description: 'Handle 80% of customer inquiries automatically. 24/7 support without hiring additional staff.',
        icon: 'tabler:headset',
      },
      {
        title: 'Community Management',
        description: 'Moderate discussions, welcome new members, answer FAQs, and keep your community engaged.',
        icon: 'tabler:users',
      },
      {
        title: 'Personal Assistant',
        description: 'Schedule meetings, set reminders, track habits, manage tasks, and stay organized.',
        icon: 'tabler:calendar',
      },
      {
        title: 'E-commerce Automation',
        description: 'Process orders, track shipments, handle returns, and provide product recommendations.',
        icon: 'tabler:shopping-bag',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611162617474-5b21e879e113?auto=format&fit=crop&w=1740&q=80',
      alt: 'AI Assistant Use Cases',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Built for Every Scenario
      </h3>
      From customer service to personal productivity, CinaClaw adapts to your needs.
    </Fragment>
  </Content>

  <!-- How It Works ******************* -->
  <Content
    tagline="How It Works"
    title="Setup in Three Steps"
    items={[
      {
        title: 'Connect Platform',
        description: 'Link your messaging platform (QQ, WeChat, Telegram, etc.) with simple OAuth or bot token.',
        icon: 'tabler:plug',
      },
      {
        title: 'Configure Behavior',
        description: 'Set up conversation flows, automate responses, and customize personality to match your brand.',
        icon: 'tabler:settings',
      },
      {
        title: 'Launch & Monitor',
        description: 'Deploy your bot and monitor performance through real-time analytics dashboard.',
        icon: 'tabler:rocket',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1556157382-97eda2d62296?auto=format&fit=crop&w=1740&q=80',
      alt: 'Setup Process',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Get Started in Minutes
      </h3>
      No coding required. Our intuitive interface makes bot creation accessible to everyone.
    </Fragment>
  </Content>

  <!-- Demo Section ******************* -->
  <section id="demo" class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          See CinaClaw in Action
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Experience the power of intelligent automation
        </p>
      </div>

      <div class="max-w-4xl mx-auto bg-gray-100 dark:bg-gray-800 rounded-2xl p-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
          <div class="p-6 bg-white dark:bg-gray-700 rounded-xl">
            <div class="text-4xl mb-4">💬</div>
            <h3 class="font-bold dark:text-white mb-2">Live Chat</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">Natural conversations that feel human</p>
          </div>
          <div class="p-6 bg-white dark:bg-gray-700 rounded-xl">
            <div class="text-4xl mb-4">⚡</div>
            <h3 class="font-bold dark:text-white mb-2">Fast Response</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">Instant replies, 24/7 availability</p>
          </div>
          <div class="p-6 bg-white dark:bg-gray-700 rounded-xl">
            <div class="text-4xl mb-4">🎯</div>
            <h3 class="font-bold dark:text-white mb-2">Smart Actions</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300">Automated tasks and workflows</p>
          </div>
        </div>

        <div class="mt-8 text-center">
          <a href="/contact" class="inline-flex items-center px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white font-medium rounded-lg transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Watch Video Demo
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section **************** -->
  <Pricing
    id="pricing"
    tagline="Pricing Plans"
    title="Simple, Transparent Pricing"
    subtitle="Start free and upgrade as you grow"
    items={[
      {
        title: 'Free',
        price: '$0',
        period: '/month',
        description: 'Perfect for personal use and testing',
        features: [
          '1 platform connection',
          '1,000 messages/month',
          'Basic AI responses',
          '3 custom commands',
          'Community support',
        ],
        action: {
          text: 'Start Free',
          href: '#',
          variant: 'secondary',
        },
      },
      {
        title: 'Pro',
        price: '¥44',
        period: '/month',
        description: 'For power users and small teams',
        features: [
          'Unlimited platforms',
          '50,000 messages/month',
          'Advanced AI (Claude/GPT)',
          'Unlimited custom commands',
          'Priority support',
          'Analytics dashboard',
          'Custom integrations',
          'Scheduled tasks',
        ],
        action: {
          text: 'Start Pro Trial',
          href: '#',
          variant: 'primary',
        },
        popular: true,
      },
      {
        title: 'Enterprise',
        price: 'Custom',
        period: '',
        description: 'For large-scale deployments',
        features: [
          'Unlimited everything',
          'Custom AI training',
          'Dedicated support',
          'SLA guarantee',
          'On-premise option',
          'White-label branding',
          'Advanced security',
          'API access',
        ],
        action: {
          text: 'Contact Sales',
          href: '/contact',
          variant: 'secondary',
        },
      },
    ]}
  />

  <!-- Testimonials ******************* -->
  <Testimonials
    title="Loved by Users"
    testimonials={[
      {
        testimonial: `CinaClaw handles 80% of our customer inquiries automatically. Our support team can now focus on complex issues. ROI was evident in week one.`,
        name: 'Lisa Wang',
        job: 'Customer Success Manager, TechStart',
        image: {
          src: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&w=500&q=80',
          alt: 'Lisa Wang',
        },
      },
      {
        testimonial: `I use CinaClaw to manage my Discord community of 10,000+ members. It moderates, welcomes new members, and answers FAQs 24/7. Absolutely essential.`,
        name: 'David Kim',
        job: 'Community Manager, GameHub',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=500&q=80',
          alt: 'David Kim',
        },
      },
      {
        testimonial: `As a solopreneur, CinaClaw is my virtual assistant. It schedules meetings, sends reminders, and even helps with customer onboarding. Worth every penny.`,
        name: 'Emma Chen',
        job: 'Founder, SoloVenture',
        image: {
          src: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80',
          alt: 'Emma Chen',
        },
      },
    ]}
  />

  <!-- Call to Action *************** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Try Free Now',
        href: '#',
        icon: 'tabler:rocket',
      },
      {
        variant: 'secondary',
        text: 'Talk to Sales',
        href: '/contact',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to <span class="text-orange-600 dark:text-orange-400">Automate</span> Your Workflow?
    </Fragment>

    <Fragment slot="subtitle">
      Join thousands of users saving time with CinaClaw. <br class="hidden md:inline" />
      Start your free trial today, no credit card required.
    </Fragment>
  </CallToAction>
</Layout>
