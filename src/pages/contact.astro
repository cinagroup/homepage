---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Form from '~/components/ui/Form.astro';

const metadata = {
  title: 'Contact Us — Get in Touch',
  description: 'Have questions? We\'d love to hear from you. Send us a message and we\'ll respond as soon as possible.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->
  <Hero
    tagline="Contact Us"
    title={'Let\'s <span class="text-accent dark:text-white">Start a Conversation</span>'}
    subtitle="Have questions about our products? Need help with integration? We're here to help!"
    image={{ 
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'Contact Us' 
    }}
  />

  <!-- Contact Form Section ********** -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Contact Information -->
        <div>
          <h2 class="text-3xl font-bold dark:text-white mb-6">Get in Touch</h2>
          <p class="text-gray-600 dark:text-gray-300 mb-8">
            Fill out the form and our team will get back to you within 24 hours.
          </p>

          <div class="space-y-6">
            <!-- Email -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">Email Us</h3>
                <p class="text-gray-600 dark:text-gray-300">hello@cinagroup.com</p>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">We'll respond within 24 hours</p>
              </div>
            </div>

            <!-- Discord -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">Join Discord</h3>
                <p class="text-gray-600 dark:text-gray-300">Community support & discussions</p>
                <a href="#" class="text-blue-600 dark:text-blue-400 hover:underline text-sm mt-1 inline-block">discord.gg/cinagroup →</a>
              </div>
            </div>

            <!-- Twitter -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">Follow on Twitter</h3>
                <p class="text-gray-600 dark:text-gray-300">@CinaGroup</p>
                <a href="https://twitter.com/cinagroup" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline text-sm mt-1 inline-block">twitter.com/cinagroup →</a>
              </div>
            </div>

            <!-- Office -->
            <div class="flex items-start">
              <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold dark:text-white mb-1">Visit Us</h3>
                <p class="text-gray-600 dark:text-gray-300">Beijing, China</p>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">By appointment only</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-8 shadow-lg">
          <h2 class="text-2xl font-bold dark:text-white mb-6">Send us a Message</h2>
          
          <form class="space-y-6" action="#" method="POST">
            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Full Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                placeholder="John Doe"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Email Address *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                placeholder="john@example.com"
              />
            </div>

            <!-- Company -->
            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Company (Optional)
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                placeholder="Your company"
              />
            </div>

            <!-- Subject -->
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Subject *
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              >
                <option value="">Select a subject</option>
                <option value="sales">Sales Inquiry</option>
                <option value="support">Technical Support</option>
                <option value="partnership">Partnership</option>
                <option value="careers">Careers</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Message *
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
                placeholder="Tell us how we can help..."
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="w-full px-6 py-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors focus:ring-4 focus:ring-blue-500/50"
            >
              Send Message
            </button>

            <p class="text-xs text-gray-500 dark:text-gray-400 text-center">
              By submitting this form, you agree to our Privacy Policy and Terms of Service.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Section ******************** -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Quick answers to common questions
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-4">
        <!-- FAQ Item 1 -->
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <h3 class="font-bold dark:text-white mb-2">What's the typical response time?</h3>
          <p class="text-gray-600 dark:text-gray-300">
            We typically respond to all inquiries within 24 hours during business days. For urgent matters, please mention "URGENT" in your subject line.
          </p>
        </div>

        <!-- FAQ Item 2 -->
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <h3 class="font-bold dark:text-white mb-2">Do you offer enterprise support?</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Yes! Enterprise customers get dedicated support with SLA guarantees, priority response, and a dedicated account manager.
          </p>
        </div>

        <!-- FAQ Item 3 -->
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <h3 class="font-bold dark:text-white mb-2">Can I schedule a demo?</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Absolutely! Select "Sales Inquiry" in the contact form and we'll schedule a personalized demo at your convenience.
          </p>
        </div>

        <!-- FAQ Item 4 -->
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6">
          <h3 class="font-bold dark:text-white mb-2">Do you have office hours?</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Our support team is available Monday to Friday, 9:00 AM - 6:00 PM (GMT+8). For critical issues, we provide 24/7 emergency support for enterprise customers.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
