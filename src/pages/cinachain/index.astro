---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'CinaChain — High-Performance Blockchain Infrastructure',
  description: 'Decentralized blockchain network with smart contracts, DeFi protocols, and Web3 infrastructure',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->
  <Hero
    tagline="区块链网络"
    title={'Next-Gen <span class="text-purple-600 dark:text-purple-400">Blockchain Infrastructure</span>'}
    subtitle="CinaChain is a high-performance, low-cost decentralized blockchain network. Build scalable dApps with smart contracts, DeFi protocols, and seamless cross-chain interoperability."
    actions={[
      {
        variant: 'primary',
        text: 'Start Building',
        href: '#developers',
        icon: 'tabler:code',
      },
      { 
        text: 'View Explorer', 
        href: '#explorer',
        icon: 'tabler:search',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1639762681485-074b7f938ba0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaChain Blockchain Network' 
    }}
  />

  <!-- Stats Section ****************** -->
  <Stats
    stats={[
      { title: 'Transactions/Day', amount: '2M+' },
      { title: 'Active Nodes', amount: '500+' },
      { title: 'Total Value Locked', amount: '$50M+' },
      { title: 'dApps Deployed', amount: '200+' },
    ]}
  />

  <!-- Features Section *************** -->
  <Features
    id="features"
    tagline="Core Features"
    title="Enterprise-Grade Blockchain"
    subtitle="Built for scalability, security, and decentralization"
    items={[
      {
        title: 'High Throughput',
        description: '10,000+ TPS with sub-second finality. Scale your dApp without compromising performance.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Low Transaction Costs',
        description: 'Average gas fee < $0.01. Perfect for microtransactions and high-frequency applications.',
        icon: 'tabler:coin',
      },
      {
        title: 'Smart Contracts',
        description: 'EVM-compatible smart contracts. Deploy Solidity contracts with familiar tooling.',
        icon: 'tabler:file-code',
      },
      {
        title: 'Cross-Chain Bridge',
        description: 'Seamlessly transfer assets between Ethereum, BSC, Polygon, and other major chains.',
        icon: 'tabler:arrows-left-right',
      },
      {
        title: 'DeFi Protocols',
        description: 'Native DEX, lending, staking, and yield farming protocols built on CinaChain.',
        icon: 'tabler:percentage',
      },
      {
        title: 'NFT Marketplace',
        description: 'Mint, trade, and showcase NFTs with low fees and fast transactions.',
        icon: 'tabler:photo',
      },
    ]}
  />

  <!-- Network Info ******************* -->
  <section id="explorer" class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Network Status
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Real-time blockchain metrics
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6 text-center shadow-lg">
          <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">Block Height</div>
          <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">12,847,593</div>
          <div class="text-xs text-green-500 mt-1">▲ +2.3 blocks/sec</div>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6 text-center shadow-lg">
          <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">Gas Price</div>
          <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">0.008 GWEI</div>
          <div class="text-xs text-green-500 mt-1">▼ -5.2% today</div>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6 text-center shadow-lg">
          <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">Active Validators</div>
          <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">127</div>
          <div class="text-xs text-gray-500 mt-1">99.9% uptime</div>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-xl p-6 text-center shadow-lg">
          <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">24h Transactions</div>
          <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">2.4M</div>
          <div class="text-xs text-green-500 mt-1">▲ +12% vs yesterday</div>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="#" class="inline-flex items-center px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-lg transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          Open Block Explorer
        </a>
      </div>
    </div>
  </section>

  <!-- Developer Resources ************ -->
  <Content
    isReversed
    id="developers"
    tagline="For Developers"
    title="Build on CinaChain"
    items={[
      {
        title: 'Comprehensive Documentation',
        description: 'Step-by-step guides, API references, and best practices for building on CinaChain.',
        icon: 'tabler:book',
      },
      {
        title: 'Developer Tools',
        description: 'SDKs for JavaScript, Python, Go. CLI tools, testnets, and local development environments.',
        icon: 'tabler:tools',
      },
      {
        title: 'Grants Program',
        description: 'Apply for funding up to $100K for innovative projects building on CinaChain.',
        icon: 'tabler:wallet',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Developer Resources',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Developer-Friendly Ecosystem
      </h3>
      <p class="text-gray-600 dark:text-gray-300 mb-4">
        Everything you need to build, deploy, and scale your dApps on CinaChain.
      </p>
      <div class="bg-gray-800 dark:bg-gray-900 rounded-lg p-4 font-mono text-sm overflow-x-auto">
        <code class="text-green-400"># Install CinaChain SDK</code><br>
        <span class="text-white">npm install @cinachain/web3</span><br><br>
        <code class="text-green-400"># Connect to network</code><br>
        <span class="text-white">const provider = new CinaChain.Provider('mainnet');</span><br><br>
        <code class="text-green-400"># Deploy contract</code><br>
        <span class="text-white">cinachain deploy ./MyContract.sol</span>
      </div>
    </Fragment>
  </Content>

  <!-- Ecosystem ******************** -->
  <Content
    tagline="Ecosystem"
    title="Growing Web3 Ecosystem"
    items={[
      {
        title: 'DeFi Applications',
        description: 'DEXs, lending protocols, yield aggregators, and derivatives platforms.',
        icon: 'tabler:chart-pie',
      },
      {
        title: 'NFT Projects',
        description: 'Art collections, gaming NFTs, metaverse assets, and digital collectibles.',
        icon: 'tabler:photo',
      },
      {
        title: 'Gaming & Metaverse',
        description: 'Play-to-earn games, virtual worlds, and blockchain-based gaming platforms.',
        icon: 'tabler:player-play',
      },
      {
        title: 'Enterprise Solutions',
        description: 'Supply chain tracking, identity verification, and enterprise blockchain solutions.',
        icon: 'tabler:building',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1639322537228-f710d846310a?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Web3 Ecosystem',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Thriving Ecosystem
      </h3>
      <p class="text-gray-600 dark:text-gray-300 mb-4">
        Join 200+ projects already building on CinaChain.
      </p>
      <div class="grid grid-cols-3 gap-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">50+</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">DeFi Protocols</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">80+</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">NFT Collections</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-purple-600 dark:text-purple-400">70+</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">Gaming Projects</div>
        </div>
      </div>
    </Fragment>
  </Content>

  <!-- Security & Consensus ********** -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Secure & Decentralized
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Built with security and decentralization at its core
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="p-6 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="font-bold dark:text-white mb-2">Proof of Stake</h3>
          <p class="text-sm text-gray-600 dark:text-gray-300">Energy-efficient consensus with 127 active validators ensuring network security.</p>
        </div>

        <div class="p-6 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="font-bold dark:text-white mb-2">Audited Smart Contracts</h3>
          <p class="text-sm text-gray-600 dark:text-gray-300">All core contracts audited by CertiK and Trail of Bits.</p>
        </div>

        <div class="p-6 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-bold dark:text-white mb-2">Global Decentralization</h3>
          <p class="text-sm text-gray-600 dark:text-gray-300">500+ nodes across 40+ countries ensuring censorship resistance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs Section ******************* -->
  <FAQs
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about CinaChain"
    tagline="FAQs"
    classes={{ container: 'max-w-4xl' }}
    items={[
      {
        title: 'What consensus mechanism does CinaChain use?',
        description: 'CinaChain uses a Proof of Stake (PoS) consensus mechanism with 127 active validators. This ensures energy efficiency while maintaining high security and decentralization.',
      },
      {
        title: 'Is CinaChain EVM-compatible?',
        description: 'Yes! CinaChain is fully EVM-compatible. You can deploy existing Solidity smart contracts and use familiar tools like MetaMask, Hardhat, and Remix without modification.',
      },
      {
        title: 'How do I bridge assets to CinaChain?',
        description: 'Use our official cross-chain bridge to transfer assets from Ethereum, BSC, Polygon, and other major chains. The bridge is secure, fast, and supports all major tokens.',
      },
      {
        title: 'What are the transaction fees on CinaChain?',
        description: 'Average transaction fees on CinaChain are less than $0.01, making it one of the most cost-effective blockchain networks for both users and developers.',
      },
      {
        title: 'How can I apply for the grants program?',
        description: 'Visit our grants portal and submit your project proposal. We fund projects in DeFi, NFTs, gaming, infrastructure, and enterprise solutions. Grants range from $10K to $100K.',
      },
    ]}
  />

  <!-- Call to Action *************** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Building',
        href: '#developers',
        icon: 'tabler:rocket',
      },
      {
        variant: 'secondary',
        text: 'Read Docs',
        href: '#',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to <span class="text-purple-600 dark:text-purple-400">Build on CinaChain</span>?
    </Fragment>

    <Fragment slot="subtitle">
      Join 200+ projects building the future of Web3. <br class="hidden md:inline" />
      Get started with our comprehensive developer resources.
    </Fragment>
  </CallToAction>
</Layout>
