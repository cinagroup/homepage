---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'About Us — CinaGroup',
  description: "Learn about CinaGroup's mission to democratize AI and Web3 technology for everyone.",
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->
  <Hero
    tagline="About Us"
    title={'Building the <span class="text-accent dark:text-white">Future of Technology</span>'}
    subtitle="We're on a mission to make AI and Web3 accessible, affordable, and useful for everyone."
    image={{ 
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'CinaGroup Team' 
    }}
  />

  <!-- Mission Section *************** -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold dark:text-white mb-6">Our Mission</h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
          "To democratize AI and Web3 technology, making it accessible, affordable, and useful for everyone."
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
          <div class="p-6 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
            <div class="text-4xl mb-4">🎯</div>
            <h3 class="font-bold dark:text-white mb-2">Accessibility</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              Breaking down technical barriers so anyone can leverage cutting-edge technology
            </p>
          </div>
          <div class="p-6 bg-green-50 dark:bg-green-900/20 rounded-xl">
            <div class="text-4xl mb-4">💰</div>
            <h3 class="font-bold dark:text-white mb-2">Affordability</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              Providing enterprise-grade solutions at prices that work for everyone
            </p>
          </div>
          <div class="p-6 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
            <div class="text-4xl mb-4">⚡</div>
            <h3 class="font-bold dark:text-white mb-2">Usefulness</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">
              Building practical tools that solve real-world problems
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Section **************** -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
        <div>
          <h2 class="text-3xl font-bold dark:text-white mb-6">Our Story</h2>
          <div class="space-y-4 text-gray-600 dark:text-gray-300">
            <p>
              Founded in 2024, CinaGroup emerged from a simple observation: while AI and blockchain technologies were advancing rapidly, they remained inaccessible to most people and businesses.
            </p>
            <p>
              Our founders, a team of engineers and entrepreneurs from leading tech companies, set out to change this. They believed that the benefits of these transformative technologies should be available to everyone, not just large corporations with deep pockets.
            </p>
            <p>
              Today, we serve over 50,000 users worldwide, from individual developers to Fortune 500 companies. Our four product lines — CinaSeek, CinaClaw, CinaSkill, and CinaChain — work together to provide a comprehensive ecosystem of AI and Web3 solutions.
            </p>
          </div>
        </div>
        <div class="bg-white dark:bg-gray-700 rounded-2xl p-8 shadow-xl">
          <div class="space-y-6">
            <div class="flex items-center">
              <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                2024
              </div>
              <div class="ml-6">
                <h3 class="font-bold dark:text-white">Company Founded</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">Beijing, China</p>
              </div>
            </div>
            <div class="flex items-center">
              <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                2025
              </div>
              <div class="ml-6">
                <h3 class="font-bold dark:text-white">Product Launch</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">CinaSeek & CinaClaw released</p>
              </div>
            </div>
            <div class="flex items-center">
              <div class="w-16 h-16 bg-purple-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                2025
              </div>
              <div class="ml-6">
                <h3 class="font-bold dark:text-white">Platform Expansion</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">CinaSkill & CinaChain launched</p>
              </div>
            </div>
            <div class="flex items-center">
              <div class="w-16 h-16 bg-orange-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
                2026
              </div>
              <div class="ml-6">
                <h3 class="font-bold dark:text-white">Global Reach</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">50K+ users, 40+ countries</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section *************** -->
  <Features
    tagline="Our Values"
    title="What Drives Us"
    subtitle="These principles guide every decision we make and every product we build"
    items={[
      {
        title: 'User First',
        description: 'We build for users, not for investors or hype. Every feature must solve a real problem.',
        icon: 'tabler:user-heart',
      },
      {
        title: 'Transparency',
        description: 'Open about our technology, pricing, and limitations. No hidden fees or dark patterns.',
        icon: 'tabler:eye',
      },
      {
        title: 'Innovation',
        description: 'Pushing boundaries while maintaining reliability. We ship fast but never break things.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Community',
        description: 'Building in public with our users. Your feedback shapes our roadmap.',
        icon: 'tabler:users',
      },
      {
        title: 'Sustainability',
        description: 'Environmentally conscious technology. Energy-efficient AI and PoS blockchain.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Excellence',
        description: 'Good enough isn\'t enough. We obsess over details to deliver the best experience.',
        icon: 'tabler:star',
      },
    ]}
  />

  <!-- Team Section ***************** -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Leadership Team
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Experienced leaders from top tech companies
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        <!-- Team Member 1 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center text-white text-4xl font-bold">
            L
          </div>
          <h3 class="font-bold dark:text-white text-lg">Leo Chen</h3>
          <p class="text-blue-600 dark:text-blue-400 text-sm mb-2">CEO & Co-Founder</p>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Former VP at Alibaba Cloud. 15+ years in AI and cloud computing.
          </p>
        </div>

        <!-- Team Member 2 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 bg-gradient-to-br from-green-400 to-green-600 rounded-full flex items-center justify-center text-white text-4xl font-bold">
            S
          </div>
          <h3 class="font-bold dark:text-white text-lg">Sarah Wang</h3>
          <p class="text-green-600 dark:text-green-400 text-sm mb-2">CTO & Co-Founder</p>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Ex-Google AI researcher. PhD in Machine Learning from MIT.
          </p>
        </div>

        <!-- Team Member 3 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 bg-gradient-to-br from-purple-400 to-purple-600 rounded-full flex items-center justify-center text-white text-4xl font-bold">
            M
          </div>
          <h3 class="font-bold dark:text-white text-lg">Mike Zhang</h3>
          <p class="text-purple-600 dark:text-purple-400 text-sm mb-2">CPO & Co-Founder</p>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Previously led product at Tencent. Built products used by 100M+ users.
          </p>
        </div>

        <!-- Team Member 4 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 bg-gradient-to-br from-orange-400 to-orange-600 rounded-full flex items-center justify-center text-white text-4xl font-bold">
            E
          </div>
          <h3 class="font-bold dark:text-white text-lg">Emma Liu</h3>
          <p class="text-orange-600 dark:text-orange-400 text-sm mb-2">COO</p>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Former operations director at ByteDance. Expert in scaling startups.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section **************** -->
  <Stats
    stats={[
      { title: 'Team Members', amount: '50+' },
      { title: 'Countries Served', amount: '40+' },
      { title: 'Active Users', amount: '50K+' },
      { title: 'Funding Raised', amount: '$20M' },
    ]}
  />

  <!-- Investors Section ************ -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Backed by the Best
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Supported by leading venture capital firms and angel investors
        </p>
      </div>

      <div class="flex flex-wrap justify-center items-center gap-12 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-2xl font-bold text-gray-400 dark:text-gray-500">Sequoia China</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-gray-400 dark:text-gray-500">Hillhouse Capital</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-gray-400 dark:text-gray-500">Qiming Venture</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-gray-400 dark:text-gray-500">IDG Capital</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action *************** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Join Our Team',
        href: '#',
        icon: 'tabler:rocket',
      },
      {
        variant: 'secondary',
        text: 'Contact Us',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Want to <span class="text-accent dark:text-white">Make an Impact</span>?
    </Fragment>

    <Fragment slot="subtitle">
      We're always looking for talented people to join our mission. <br class="hidden md:inline" />
      Check out our open positions or get in touch.
    </Fragment>
  </CallToAction>
</Layout>
