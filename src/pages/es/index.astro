---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'CinaGroup — Soluciones de IA y Web3',
  description: 'CinaGroup ofrece soluciones de vanguardia en búsqueda con IA (CinaSeek), robots inteligentes (CinaClaw), plataforma de habilidades (CinaSkill) e infraestructura blockchain (CinaChain).',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Bienvenido a CinaGroup"
    title={'Construyendo el futuro de <span class="text-accent dark:text-white">IA y Web3</span>'}
    subtitle="Proporcionamos soluciones de vanguardia en búsqueda con IA, robots inteligentes, plataforma de habilidades e infraestructura blockchain. Impulsando empresas y desarrolladores en todo el mundo."
    actions={[
      {
        variant: 'primary',
        text: 'Explorar Productos',
        href: '#business',
        icon: 'tabler:arrow-down',
      },
      { 
        text: 'Contacto', 
        href: '/es/contact',
        icon: 'tabler:mail',
      },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', 
      alt: 'Tecnología IA' 
    }}
  />

  <section id="business" class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl mb-4">
          Nuestras Líneas de Negocio
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Cuatro plataformas potentes trabajan juntas para ofrecer soluciones integrales de IA y Web3
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {['CinaSeek', 'CinaClaw', 'CinaSkill', 'CinaChain'].map((name, i) => (
          <div class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
            <div class={`absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-${['green', 'orange', 'pink', 'purple'][i]}-400 to-${['green', 'orange', 'pink', 'purple'][i]}-600`}></div>
            <div class="p-6">
              <h3 class="text-xl font-bold dark:text-white mb-2">{name}</h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">
                {['Búsqueda Inteligente', 'Asistente IA', 'Plataforma de Habilidades', 'Red Blockchain'][i]}
              </p>
              <a href={`/es/${name.toLowerCase()}`} class={`inline-flex items-center text-${['green', 'orange', 'pink', 'purple'][i]}-600 dark:text-${['green', 'orange', 'pink', 'purple'][i]}-400 font-medium text-sm`}>
                Más Información
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
